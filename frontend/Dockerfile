# ─── Frontend Dockerfile ─────────────────────
# Stage: development (Vite hot-reload dev server)
# ─────────────────────────────────────────────
FROM node:20-alpine AS development

WORKDIR /app

# Install dependencies first (Docker layer cache)
COPY package*.json ./
RUN npm install

# Copy source (overridden by volume mount in dev)
COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
